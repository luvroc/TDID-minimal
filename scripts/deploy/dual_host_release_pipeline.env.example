REMOTE_USER=ecs-user
PRIMARY_HOST=tee-a.example.internal
SECONDARY_HOSTS_CSV=tee-b.example.internal
RELEASE_ID=20260401a3p1

REMOTE_MINIMAL_DIR=/opt/tdid/tdid-remote-minimal
REMOTE_REPO_DIR=/opt/tdid/tdid-open-minimal/tee
OCCLUM_BIN=/opt/occlum/build/bin/occlum
OCCLUM_GO=/opt/occlum/toolchains/golang/bin/occlum-go

PIPELINE_MODE=promote-only
ALLOW_UNSTABLE_BUILD_FROM_SOURCE=0
BUILD_ENV=CC=/opt/occlum/toolchains/gcc/bin/occlum-gcc
BUILD_CMD=/opt/occlum/toolchains/golang/bin/occlum-go build
BUILD_TARGET=./enclave/cmd/tee_enclave_service
BUILD_OUTPUT_BASENAME=tee_enclave_service
EXPECTED_INTERPRETER=/lib/ld-musl-x86_64.so.1

REBUILD_INSTANCE=1
RESTART_SERVICES=1
RUN_CLOSEOUT_ON_PRIMARY=1
DRY_RUN=1
